{
  "input": {
    "source_cloud": "./data/left_8_sv - Cloud.txt",
    "target_cloud": "./data/right_8_sv - Cloud.txt"
  },
  "preprocess": {
    "enable_txt_cache": true,
    "filter_leaf_size": 0.25,
    "mirror_axes": "x"
  },
  "pipeline": {
    "run_coarse": true,
    "run_refine": true
  },
  "coarse_registration": {
    "method": 0,
    "voxel_size": 0.2,
    "max_correspondence_distance": 50.0,
    "max_iterations": 260,
    "use_initial_guess": false,
    "initial_transform_json": ""
  },
  "refine_registration": {
    "method": 2,
    "voxel_size": 0.08,
    "max_correspondence_distance": 0.35,
    "max_iterations": 220,
    "use_initial_guess": true,
    "initial_transform_json": ""
  },
  "evaluation": {
    "enabled": true,
    "stages": [
      "coarse",
      "refine"
    ],
    "max_sample_points": 80000
  },
  "output": {
    "result_dir": "./result",
    "transformed_source_cloud": "transformed_source_by_registration.ply",
    "result_json": "registration_result.json",
    "initial_transform_json": "initial_transform_for_icp.json"
  }
}
