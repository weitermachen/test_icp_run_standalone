{
  "run_mode": "fusion",
  "input": {
    "source_cloud": "./data/left_13_sv - Cloud.txt",
    "target_cloud": "./data/right_13_sv - Cloud.txt"
  },
  "preprocess": {
    "enable_txt_cache": true,
    "filter_leaf_size": 0.25,
    "noise_filter": {
      "enabled": true,
      "mean_k": 20,
      "stddev_mul_thresh": 1.0
    },
    "mirror_axes": "x"
  },
  "pipeline": {
    "run_coarse": true,
    "run_refine": true
  },
  "coarse_registration": {
    "method": 0,
    "voxel_size": 0.2,
    "max_correspondence_distance": 50.0,
    "max_iterations": 260,
    "use_initial_guess": false,
    "initial_transform_json": ""
  },
  "refine_registration": {
    "method": 2,
    "voxel_size": 0.08,
    "max_correspondence_distance": 0.35,
    "max_iterations": 220,
    "use_initial_guess": true,
    "initial_transform_json": ""
  },
  "evaluation": {
    "enabled": true,
    "stages": [
      "coarse",
      "refine"
    ],
    "max_sample_points": 80000
  },
  "output": {
    "result_dir": "./result",
    "transformed_source_cloud": "transformed_source_by_registration.ply",
    "result_json": "registration_result.json",
    "initial_transform_json": "initial_transform_for_icp.json"
  },
  "fusion": {
    "candidate_result_dir": "./result",
    "data_dir": "./data",
    "output_json": "fused_registration_result.json",
    "max_sample_points_per_pair": 50000,
    "optimization_sample_points_per_pair": 8000,
    "trim_ratio": 0.1,
    "max_refine_rmse": 1.5,
    "optimization_max_iterations": 40,
    "optimization_rotation_step_deg": 0.5,
    "optimization_translation_step": 0.5,
    "optimization_min_rotation_step_deg": 0.005,
    "optimization_min_translation_step": 0.01
  }
}
